# ===========================================
# Server
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# MongoDB
# ===========================================
# 로컬
MONGODB_URI=mongodb://localhost:27017/drvt-mall

# MongoDB Atlas — mongodb:// 표준 연결 문자열 권장 (Windows에서 mongodb+srv SRV DNS 오류 방지)
# Atlas → Connect → Drivers → "Standard connection string" 복사
# MONGODB_URI=mongodb://<username>:<password>@<host0>:27017,<host1>:27017,<host2>:27017/drvt-mall?ssl=true&authSource=admin&retryWrites=true&w=majority

# Atlas SRV (일부 Windows/Node 환경에서 querySrv ECONNREFUSED 발생 가능)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/drvt-mall?retryWrites=true&w=majority

# ===========================================
# JWT (인증 토큰)
# ===========================================
# 프로덕션에서는 반드시 긴 랜덤 문자열로 변경 (예: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_key_here

# ===========================================
# 이메일 — Resend (OTP 발송)
# ===========================================
# Resend API 키: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# 발신 주소 (Resend에서 인증된 도메인 또는 onboarding@resend.dev 테스트용)
EMAIL_FROM=DRVT Mall <onboarding@resend.dev>

# 개발 환경에서 Resend 테스트 수신자 제한이 걸리면 OTP를 서버 콘솔에 출력
EMAIL_CONSOLE_FALLBACK=true

# ===========================================
# 카카오 소셜 로그인
# ===========================================
# Kakao Developers → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here

# Kakao Developers에서 Client Secret을 활성화한 경우만 입력
KAKAO_CLIENT_SECRET=

# Kakao Developers → 카카오 로그인 → Redirect URI에 동일하게 등록
KAKAO_REDIRECT_URI=http://localhost:5000/api/auth/kakao/callback

# OAuth 성공 후 돌아갈 프론트엔드 주소
CLIENT_URL=http://localhost:5173

# ===========================================
# 구글 소셜 로그인
# ===========================================
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Client의 Authorized redirect URIs에 동일하게 등록
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ===========================================
# 네이버 소셜 로그인
# ===========================================
# Naver Developers → 내 애플리케이션 → Client ID / Client Secret
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Naver Developers → API 설정 → Callback URL에 동일하게 등록
NAVER_REDIRECT_URI=http://localhost:5000/api/auth/naver/callback

# ===========================================
# 포트원 (결제 검증)
# ===========================================
# 포트원 콘솔 → 결제 연동 → 연동 정보 → API Keys → V2 API Secret
PORTONE_V2_API_SECRET=your_portone_v2_api_secret_here
